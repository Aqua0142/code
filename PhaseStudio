              </div>
              <div className="flex items-center gap-2">
                <button
                  onClick={(e) => {
                    e.stopPropagation();
                    onToggle(idx);
                  }}
                  className={`${item.isMandatory || item.isBookmarked ? "text-orange-500" : "text-slate-600 hover:text-orange-400"}`}
                >
                  {item.isMandatory || item.isBookmarked ? (
                    <BookmarkCheck size={14} />
